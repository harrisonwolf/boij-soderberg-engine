# Build output
/build/
/dist/

# Python tool caches
__pycache__/
*.py[cod]

# C/C++ compilation artifacts
*.o
*.obj
*.gch
*.a
*.so
*.dylib
*.dll

# Generic binaries / run outputs
*.out

# IDE / editor backups
*~
\#*\#
.\#*
*.swp
# Local incomplete/quarantined benchmark diagnostics
/benchmarks/runs/.staging-*/
/benchmarks/runs/quarantine/

*.swo

# OS junk
.DS_Store
Thumbs.db

# Keep archived historical artifacts tracked
!research/snapshots/**
!research/archive/generated/**
!research/archive/editor-backups/**

# Exclude generated burnfiles and backup snapshots from version control
**/burnfiles/
research/archive/editor-backups/
research/snapshots/cppCode_backup_*/
